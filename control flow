int main() {
    int x = 10;
    int i;

    if (x > 5) {
        printf("x is greater than 5\n");
    } else {
        printf("x is 5 or less\n");
    }

    switch (x) {
        case 10:
            printf("x is exactly 10\n");
            break;
        default:
            printf("x is not 10\n");
    }

    for (i = 0; i < 3; i++) {
        printf("For loop iteration: %d\n", i);
    }

    while (x > 7) {
        printf("While loop x: %d\n", x);
        x--;
    }

    return 0;
}
