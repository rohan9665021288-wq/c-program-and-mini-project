#include <stdio.h>
#include <stdbool.h> // Required for bool type

int main() {
  
    int age = 25;

 
    float height = 5.9;

   
    double distance = 12345.6789;

    char grade = 'A';

     bool isStudent = true;

   
    printf("Age: %d\n", age);         
    printf("Height: %.1f\n", height);  
    printf("Distance: %lf\n", distance); 
    printf("Grade: %c\n", grade);      
    printf("Is Student: %d\n", isStudent); 

    return 0;
}
